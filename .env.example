# Cloud Decoded — Environment Variable Template
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Supabase / Postgres ──────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Redis (LangGraph checkpointing) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Default LLM keys (operator keys — used when workspace BYOK not configured)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── AWS (operator account — for provider abstraction layer) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Azure (operator account) ─────────────────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ── Platform ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Fernet key for BYOK secret encryption at rest
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Local dev ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
