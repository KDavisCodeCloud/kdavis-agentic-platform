# Cloud Decoded — Environment Variable Template
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Supabase / Postgres ──────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Redis (LangGraph checkpointing) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...        # Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=whsec_...     # Dashboard → Developers → Webhooks → signing secret

# Stripe Price IDs — create one monthly recurring price per tier in the Dashboard
# Dashboard → Products → Add product → add price → copy price_id (price_...)
STRIPE_PRICE_ID_STARTER=price_...   # $299/month
STRIPE_PRICE_ID_GROWTH=price_...    # $699/month
STRIPE_PRICE_ID_ENTERPRISE=price_... # $2,499/month

# ── Social publishing OAuth (Phase 2 — content pipeline) ─────────────────────
# LinkedIn: Dashboard → My Apps → create app → Auth tab → copy client ID/secret
# Required scopes: openid, profile, w_member_social
# Redirect URI to register: {API_BASE_URL}/api/v1/content/connect/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X (Twitter): developer.twitter.com → Projects & Apps → create app → Keys & Tokens
# Required scopes: tweet.write, users.read, offline.access  (OAuth 2.0 with PKCE)
# Redirect URI to register: {API_BASE_URL}/api/v1/content/connect/callback/x
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── Default LLM keys (operator keys — used when workspace BYOK not configured)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── AWS (operator account — for provider abstraction layer) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Azure (operator account) ─────────────────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ── Platform ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Fernet key for BYOK secret encryption at rest
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Local dev ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Systeme.io ────────────────────────────────────────────────────────────────
SYSTEME_API_KEY=

# Cloud Decoded tags (create in systeme.io → Settings → Tags)
SYSTEME_TAG_CD_COLD_SEQ_1=
SYSTEME_TAG_CD_TRIAL_ONBOARD=
SYSTEME_TAG_CD_TRIAL_CONVERT=
SYSTEME_TAG_CD_CHURN_SAVE=
SYSTEME_TAG_CD_EXPANSION=

# MSE tags
SYSTEME_TAG_MSE_COLD_SEQ_1=
SYSTEME_TAG_MSE_TRIAL_ONBOARD=
SYSTEME_TAG_MSE_TRIAL_CONVERT=
SYSTEME_TAG_MSE_CHURN_SAVE=
SYSTEME_TAG_MSE_EXPANSION=

# ── Apollo ────────────────────────────────────────────────────────────────────
APOLLO_API_KEY=
