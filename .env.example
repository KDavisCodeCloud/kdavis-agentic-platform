# Cloud Decoded — Environment Variable Template
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Supabase / Postgres ──────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Leads funnel (leads/capture/signup_handler.py, leads/integrations/slack.py) ──
SLACK_LEADS_WEBHOOK_URL=

# ── Redis (LangGraph checkpointing) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...        # Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=whsec_...     # Dashboard → Developers → Webhooks → signing secret

# Stripe Price IDs — create one monthly recurring price per tier in the Dashboard
# Dashboard → Products → Add product → add price → copy price_id (price_...)
STRIPE_PRICE_ID_STARTER=price_...   # $299/month
STRIPE_PRICE_ID_GROWTH=price_...    # $699/month
STRIPE_PRICE_ID_ENTERPRISE=price_... # $2,499/month

# ── Social publishing OAuth (Phase 2 — content pipeline) ─────────────────────
# LinkedIn: Dashboard → My Apps → create app → Auth tab → copy client ID/secret
# Required scopes: openid, profile, w_member_social
# TWO separate redirect URIs must both be registered on the LinkedIn app —
# missing the second one is what paused the internal flow on 2026-07-14:
#   Customer-facing (content.py):   {API_BASE_URL}/api/v1/content/connect/callback/linkedin
#   Internal/owner (internal_marketing.py): {API_BASE_URL}/api/v1/internal/marketing/connect/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Canva Connect API (internal marketing — image/design asset generation)
# developers.canva.com → create an "External Application" → Configuration tab
# Required scopes: asset:read asset:write design:content:read design:content:write
# Redirect URI to register: {API_BASE_URL}/api/v1/internal/marketing/connect/callback/canva
# Also requires: at least one Brand Template built in Canva's own UI with
# named autofill placeholder fields, and a Canva plan tier that includes
# Connect/Autofill API access — verify before relying on this integration.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# X (Twitter): developer.twitter.com → Projects & Apps → create app → Keys & Tokens
# Required scopes: tweet.write, users.read, offline.access  (OAuth 2.0 with PKCE)
# Redirect URI to register: {API_BASE_URL}/api/v1/content/connect/callback/x
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── Default LLM keys (operator keys — used when workspace BYOK not configured)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# ── Gemini image generation (assets_library/gemini_image_gen.py) ────────────
GEMINI_API_KEY=

# ── AWS (operator account — for provider abstraction layer) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Azure (operator account) ─────────────────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ── Platform ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=

# Fernet key for BYOK secret encryption at rest
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Local dev ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Obsidian vault sync (sop_agent → obsidian/vault_sync.py) ────────────────
# Local filesystem path to the vault root, e.g. /path/to/kdavis-agentic-platform/knowledge
OBSIDIAN_VAULT_PATH=

# ── Finance document storage (accounting_agent → finance/integrations/document_store.py) ──
# Local filesystem path for receipt/revenue-export files. LocalFileSystemStore
# only for now — S3Store exists for later, not wired in yet.
FINANCE_DOCUMENT_STORE_PATH=

# ── research_agent ────────────────────────────────────────────────────────────
# Set to "true" to enable live Reddit scraping; other sources are stubbed until built
ENABLE_LIVE_SCRAPING=false

# ── Systeme.io ────────────────────────────────────────────────────────────────
SYSTEME_API_KEY=

# Cloud Decoded tags (create in systeme.io → Settings → Tags)
SYSTEME_TAG_CD_COLD_SEQ_1=
SYSTEME_TAG_CD_TRIAL_ONBOARD=
SYSTEME_TAG_CD_TRIAL_CONVERT=
SYSTEME_TAG_CD_CHURN_SAVE=
SYSTEME_TAG_CD_EXPANSION=

# MSE tags
SYSTEME_TAG_MSE_COLD_SEQ_1=
SYSTEME_TAG_MSE_TRIAL_ONBOARD=
SYSTEME_TAG_MSE_TRIAL_CONVERT=
SYSTEME_TAG_MSE_CHURN_SAVE=
SYSTEME_TAG_MSE_EXPANSION=

# ── Apollo ────────────────────────────────────────────────────────────────────
APOLLO_API_KEY=

# ── Marketing routes (api/routes/marketing.py) — leave empty in dev for no auth
MARKETING_API_KEY=
